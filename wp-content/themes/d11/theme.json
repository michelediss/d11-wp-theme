{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "color": {
      "defaultPalette": false,
      "defaultGradients": false,
      "palette": [
        {
          "slug": "canvas",
          "name": "Canvas",
          "color": "#f6f3ec"
        },
        {
          "slug": "foreground",
          "name": "Foreground",
          "color": "#1c1917"
        },
        {
          "slug": "accent",
          "name": "Accent",
          "color": "#b85c38"
        },
        {
          "slug": "muted",
          "name": "Muted",
          "color": "#d9d1c5"
        },
        {
          "slug": "sputnik-dark",
          "name": "Sputnik Dark",
          "color": "#0A0A0A"
        },
        {
          "slug": "sputnik-cream",
          "name": "Sputnik Cream",
          "color": "#F5F0E8"
        },
        {
          "slug": "sputnik-red",
          "name": "Sputnik Red",
          "color": "#E8132A"
        },
        {
          "slug": "sputnik-orange",
          "name": "Sputnik Orange",
          "color": "#F57C20"
        }
      ]
    },
    "layout": {
      "contentSize": "48rem",
      "wideSize": "80rem"
    },
    "spacing": {
      "blockGap": "var(--wp--preset--spacing--md)",
      "defaultSpacingSizes": false,
      "spacingSizes": [
        {
          "slug": "xs",
          "name": "XS",
          "size": "0.5rem"
        },
        {
          "slug": "sm",
          "name": "SM",
          "size": "1rem"
        },
        {
          "slug": "md",
          "name": "MD",
          "size": "1.5rem"
        },
        {
          "slug": "lg",
          "name": "LG",
          "size": "3rem"
        },
        {
          "slug": "xl",
          "name": "XL",
          "size": "5rem"
        },
        {
          "slug": "2xl",
          "name": "2XL",
          "size": "6rem"
        },
        {
          "slug": "3xl",
          "name": "3XL",
          "size": "8rem"
        }
      ]
    },
    "typography": {
      "fluid": true,
      "defaultFontSizes": false,
      "fontFamilies": [
        {
          "fontFamily": "\"Instrument Sans\", \"Helvetica Neue\", sans-serif",
          "name": "Sans",
          "slug": "sans"
        },
        {
          "fontFamily": "\"Fraunces\", Georgia, serif",
          "name": "Display",
          "slug": "display"
        },
        {
          "fontFamily": "\"Space Grotesk\", sans-serif",
          "name": "Space Grotesk",
          "slug": "space-grotesk"
        },
        {
          "fontFamily": "\"Inter\", sans-serif",
          "name": "Inter",
          "slug": "inter"
        }
      ],
      "fontSizes": [
        {
          "slug": "sm",
          "name": "Small",
          "size": "0.875rem"
        },
        {
          "slug": "base",
          "name": "Base",
          "size": "1rem"
        },
        {
          "slug": "lg",
          "name": "Large",
          "size": "1.25rem"
        },
        {
          "slug": "xl",
          "name": "XL",
          "size": "clamp(2.25rem, 4vw, 4.5rem)"
        },
        {
          "slug": "hero",
          "name": "Hero",
          "size": "clamp(4rem, 9vw, 8rem)"
        }
      ]
    },
    "custom": {
      "radius": {
        "sm": "0.375rem",
        "md": "0.75rem",
        "lg": "1.5rem"
      }
    },
    "blocks": {
      "core/button": {
        "border": {
          "radius": "var(--wp--custom--radius--md)"
        }
      },
      "core/navigation": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--base)"
        }
      }
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--canvas)",
      "text": "var(--wp--preset--color--foreground)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--sans)",
      "fontSize": "var(--wp--preset--font-size--base)",
      "lineHeight": "1.6"
    },
    "elements": {
      "heading": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--display)",
          "fontWeight": "600",
          "lineHeight": "1.05"
        }
      },
      "button": {
        "border": {
          "radius": "var(--wp--custom--radius--md)"
        },
        "color": {
          "background": "var(--wp--preset--color--foreground)",
          "text": "var(--wp--preset--color--canvas)"
        },
        "spacing": {
          "padding": {
            "top": "0.75rem",
            "bottom": "0.75rem",
            "left": "1.25rem",
            "right": "1.25rem"
          }
        }
      },
      "link": {
        "color": {
          "text": "var(--wp--preset--color--accent)"
        }
      }
    }
  },
  "templateParts": [
    {
      "area": "header",
      "name": "header",
      "title": "Header"
    },
    {
      "area": "uncategorized",
      "name": "hero",
      "title": "Hero"
    },
    {
      "area": "uncategorized",
      "name": "heading-page",
      "title": "Page Heading"
    },
    {
      "area": "footer",
      "name": "footer",
      "title": "Footer"
    }
  ]
}
