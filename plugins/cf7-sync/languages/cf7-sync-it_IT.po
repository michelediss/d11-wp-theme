#: cf7-sync.php:102
#, php-format
msgid "Manifest directory not found: %s"
msgstr "Directory dei manifest non trovata: %s"

#: cf7-sync.php:123
#, php-format
msgid "No JSON manifests found in %s"
msgstr "Nessun manifest JSON trovato in %s"

#: cf7-sync.php:141
#, php-format
msgid "Duplicate slug \"%1$s\" found in %2$s and %3$s"
msgstr "Slug duplicato \"%1$s\" trovato in %2$s e %3$s"

#: cf7-sync.php:154
#, php-format
msgid "No manifest found for slug \"%s\""
msgstr "Nessun manifest trovato per lo slug \"%s\""

#: cf7-sync.php:163
#, php-format
msgid "Unable to read manifest file: %s"
msgstr "Impossibile leggere il file manifest: %s"

#: cf7-sync.php:168
#, php-format
msgid "Invalid JSON in %1$s: %2$s"
msgstr "JSON non valido in %1$s: %2$s"

#: cf7-sync.php:172
#, php-format
msgid "Manifest must decode to an object: %s"
msgstr "Il manifest deve decodificarsi in un oggetto: %s"

#: cf7-sync.php:189
#, php-format
msgid "Missing or invalid \"slug\" in %s"
msgstr "\"slug\" mancante o non valido in %s"

#: cf7-sync.php:193
#, php-format
msgid "Missing \"title\" in %s"
msgstr "\"title\" mancante in %s"

#: cf7-sync.php:197
#, php-format
msgid "Missing \"form\" in %s"
msgstr "\"form\" mancante in %s"

#: cf7-sync.php:206
#, php-format
msgid "Missing \"%1$s\" in %2$s"
msgstr "\"%1$s\" mancante in %2$s"

#: cf7-sync.php:213
#, php-format
msgid "\"%1$s\" must be an object in %2$s"
msgstr "\"%1$s\" deve essere un oggetto in %2$s"

#: cf7-sync.php:232
#, php-format
msgid "Missing \"%1$s.%2$s\" in %3$s"
msgstr "\"%1$s.%2$s\" mancante in %3$s"

#: cf7-sync.php:285
#, php-format
msgid "Multiple CF7 forms found for slug \"%s\""
msgstr "Trovati più moduli CF7 per lo slug \"%s\""

