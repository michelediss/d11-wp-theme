#, php-format
msgid "Unable to create form \"%1$s\": %2$s"
msgstr "Impossibile creare il modulo \"%1$s\": %2$s"

#: cf7-sync.php:320
#, php-format
msgid "Unable to bootstrap CF7 form instance for \"%s\""
msgstr "Impossibile inizializzare l'istanza del modulo CF7 per \"%s\""

#: cf7-sync.php:393
#, php-format
msgid "CF7 failed to save form \"%s\""
msgstr "CF7 non è riuscito a salvare il modulo \"%s\""

#: cf7-sync.php:497
#, php-format
msgid "CF7 sync complete%s. Created: %d, Updated: %d, Unchanged: %d"
