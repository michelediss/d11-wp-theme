{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "color": {
      "defaultGradients": false,
      "defaultPalette": false,
      "palette": [
        {
          "slug": "white",
          "name": "White",
          "color": "#ffffff"
        },
        {
          "slug": "black",
          "name": "Black",
          "color": "#111111"
        },
        {
          "slug": "light",
          "name": "Light",
          "color": "#f5efe3"
        },
        {
          "slug": "primary",
          "name": "Primary",
          "color": "#e5232f"
        },
        {
          "slug": "accent",
          "name": "Accent",
          "color": "#f58a1f"
        }
      ]
    },
    "custom": {
      "radius": {
        "sm": "0.375rem",
        "md": "0.75rem",
        "lg": "1.5rem",
        "pill": "999px"
      },
      "tracking": {
        "tight": "-0.03em",
        "wide": "0.14em"
      }
    },
    "layout": {
      "contentSize": "48rem",
      "wideSize": "80rem"
    },
    "spacing": {
      "blockGap": "var(--wp--preset--spacing--md)",
      "defaultSpacingSizes": false,
      "spacingSizes": [
        {
          "slug": "xs",
          "name": "XS",
          "size": "0.5rem"
        },
        {
          "slug": "sm",
          "name": "SM",
          "size": "1rem"
        },
        {
          "slug": "md",
          "name": "MD",
          "size": "1.5rem"
        },
        {
          "slug": "lg",
          "name": "LG",
          "size": "3rem"
        },
        {
          "slug": "xl",
          "name": "XL",
          "size": "5rem"
        },
        {
          "slug": "2xl",
          "name": "2XL",
          "size": "6rem"
        },
        {
          "slug": "3xl",
          "name": "3XL",
          "size": "8rem"
        }
      ],
      "units": [
        "px",
        "rem",
        "%",
        "vw",
        "vh"
      ]
    },
    "typography": {
      "defaultFontSizes": false,
      "fluid": true,
      "fontFamilies": [
        {
          "slug": "heading",
          "name": "Heading",
          "fontFamily": "\"Space Grotesk\", sans-serif"
        },
        {
          "slug": "paragraph",
          "name": "Paragraph",
          "fontFamily": "\"Inter\", sans-serif"
        }
      ],
      "fontSizes": [
        {
          "slug": "sm",
          "name": "Small",
          "size": "0.875rem"
        },
        {
          "slug": "base",
          "name": "Base",
          "size": "1rem"
        },
        {
          "slug": "lg",
          "name": "Large",
          "size": "1.25rem"
        },
        {
          "slug": "xl",
          "name": "XL",
          "size": "clamp(2.25rem, 4vw, 4.5rem)"
        },
        {
          "slug": "hero",
          "name": "Hero",
          "size": "clamp(4rem, 9vw, 8rem)"
        }
      ]
    },
    "blocks": {
      "core/button": {
        "border": {
          "radius": "var(--wp--custom--radius--md)"
        }
      },
      "core/buttons": {
        "spacing": {
          "blockGap": "var(--wp--preset--spacing--sm)"
        }
      },
      "core/navigation": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--paragraph)",
          "fontSize": "0.75rem",
          "fontWeight": "600",
          "letterSpacing": "0.1em",
          "textTransform": "uppercase"
        }
      }
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--light)",
      "text": "var(--wp--preset--color--black)"
    },
    "spacing": {
      "blockGap": "var(--wp--preset--spacing--md)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--paragraph)",
      "fontSize": "var(--wp--preset--font-size--base)",
      "fontWeight": "400",
      "lineHeight": "1.6"
    },
    "elements": {
      "heading": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--heading)",
          "fontWeight": "700",
          "letterSpacing": "var(--wp--custom--tracking--tight)",
          "lineHeight": "0.98"
        }
      },
      "button": {
        "border": {
          "radius": "var(--wp--custom--radius--md)"
        },
        "color": {
          "background": "var(--wp--preset--color--primary)",
          "text": "var(--wp--preset--color--white)"
        },
        "spacing": {
          "padding": {
            "top": "0.875rem",
            "right": "1.5rem",
            "bottom": "0.875rem",
            "left": "1.5rem"
          }
        },
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--paragraph)",
          "fontSize": "0.75rem",
          "fontWeight": "700",
          "letterSpacing": "var(--wp--custom--tracking--wide)",
          "textTransform": "uppercase"
        }
      },
      "link": {
        "color": {
          "text": "var(--wp--preset--color--primary)"
        }
      }
    },
    "blocks": {
      "core/post-title": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--heading)",
          "fontWeight": "700",
          "letterSpacing": "var(--wp--custom--tracking--tight)",
          "lineHeight": "0.95"
        }
      },
      "core/query-title": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--heading)",
          "fontWeight": "700",
          "letterSpacing": "var(--wp--custom--tracking--tight)",
          "lineHeight": "0.95"
        }
      },
      "core/site-title": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--heading)",
          "fontWeight": "700",
          "letterSpacing": "var(--wp--custom--tracking--tight)",
          "textTransform": "uppercase"
        }
      }
    }
  },
  "templateParts": [
    {
      "area": "header",
      "name": "header",
      "title": "Header"
    },
    {
      "area": "uncategorized",
      "name": "hero",
      "title": "Hero"
    },
    {
      "area": "uncategorized",
      "name": "heading-page",
      "title": "Page Heading"
    },
    {
      "area": "footer",
      "name": "footer",
      "title": "Footer"
    }
  ]
}
